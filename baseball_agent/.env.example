# Step 6~8 LLM 실연결을 위한 환경변수 템플릿.
# 복사: cp .env.example .env  → 실제 키 입력 → `python main.py`가 LLM 경로로 전환된다.
# 키가 없어도 Agent는 stub 폴백으로 끝까지 완주한다 (과제 채점 호환).

OPENAI_API_KEY=sk-proj-...your-key-here...

# (선택) 모델 오버라이드. 미지정 시 기본값 사용.
# OPENAI_LLM_MODEL=gpt-4o-mini
#
# 이미지 모델: gpt-image-1-mini | gpt-image-1 | gpt-image-1.5 | gpt-image-2 | dall-e-3
# OPENAI_IMAGE_MODEL=gpt-image-1-mini
#
# gpt-image-* 계열 품질: low | medium | high | auto
# OPENAI_IMAGE_QUALITY=medium
#
# OPENAI_VISION_MODEL=gpt-4o-mini
